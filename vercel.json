{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.ico$|404\\.html$).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/sync?network=testnet",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/sync?network=mainnet",
      "schedule": "*/5 * * * *"
    }
  ]
}
